{
  "rewrites":[
    {
      "source": "/trending",
      "destination": "/api/trending"
    },
    {
      "source": "/home",
      "destination": "/api/home"
    },
    {
      "source": "/:token",
      "destination": "/api/[token]"
    }
  ],
  "headers":[
    {
      "source": "/(.*)",
      "headers":[
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
